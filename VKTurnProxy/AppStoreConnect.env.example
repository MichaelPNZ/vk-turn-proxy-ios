# Prefer generating VKTurnProxy/AppStoreConnect.env with:
#   scripts/configure-testflight-env.sh --key-id ... --issuer-id ... --key-path /absolute/path/AuthKey_XXXXXXXXXX.p8
#
# Manual fallback: copy this file to VKTurnProxy/AppStoreConnect.env and fill
# from App Store Connect API Keys. Do not commit VKTurnProxy/AppStoreConnect.env
# or the .p8 private key.

APPSTORE_KEY_ID=
APPSTORE_ISSUER_ID=
APPSTORE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
