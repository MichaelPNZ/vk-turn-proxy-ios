# Environment file for /etc/vk-turn-proxy-ios.env
#
# Keep this file free of secrets in git. Copy to the server, edit there,
# then run scripts/deploy-server-vps.sh.

VKTURN_LISTEN=0.0.0.0:56004
VKTURN_CONNECT=127.0.0.1:51820
VKTURN_HEALTH_LISTEN=127.0.0.1:56080
VKTURN_LOGFILE=/var/log/vk-turn-proxy-ios.log
VKTURN_SESSION_IDLE_TIMEOUT=30m

# The fork binary defaults to 1024 concurrent SRTP sessions.
# To override it, add -max-sessions to ExecStart after confirming the
# existing production env file has the matching variable.
VKTURN_MAX_SESSIONS=1024
